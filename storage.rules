rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /course-covers/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /courses/{courseId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /instructors/{instructorId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: instructors
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (required, format: email, domain: @bu.ac.th)
    //   - position: string (required)
    //   - department: string (required)
    //   - createdAt: string (required)
    //
    // Collection: courses
    // Document ID: {courseId}
    // Fields:
    //   - title: string (required)
    //   - instructorName: string (required)
    //   - date: string (required)
    //   - description: string (optional)
    //   - imageUrl: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidEmail(email) {
      return email is string && email.matches("^[a-zA-Z0-9._%+-]+@bu\\.ac\\.th$");
    }

    function isDocOwner() {
      return isAuthenticated() && 
             resource != null && 
             'uid' in resource.data && 
             request.auth.uid == resource.data.uid;
    }

    function isRequestOwner() {
      return isAuthenticated() && 
             'uid' in request.resource.data && 
             request.auth.uid == request.resource.data.uid;
    }

    function isValidInstructor(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'department']) &&
             isValidEmail(data.email) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.department is string && data.department.size() > 0 &&
             (!('uid' in data) || (data.uid is string && data.uid.size() > 0));
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email.toLowerCase() == "kulachet.l@bu.ac.th" &&
             request.auth.token.email_verified == true;
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['courseId', 'userId', 'userName', 'userEmail', 'sequenceNumber']) &&
             data.courseId is string &&
             data.userId is string &&
             data.userName is string &&
             data.userEmail is string &&
             data.sequenceNumber is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /instructors/{instructorId} {
      allow read: if isOwner(instructorId) || 
                     isAdmin() || 
                     (isAuthenticated() && resource.data.email == request.auth.token.email) ||
                     (isAuthenticated() && resource.data.email.lower() == request.auth.token.email.lower());
      allow create: if (isOwner(instructorId) || isRequestOwner()) && isValidInstructor(request.resource.data);
      allow update: if (isOwner(instructorId) || isDocOwner() || (isAuthenticated() && resource.data.email == request.auth.token.email)) && isValidInstructor(request.resource.data);
    }

    match /courses/{courseId} {
      allow read: if true;
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sessions', 'totalRegistrations']));
      allow create, delete: if isAdmin();
    }

    match /registrations/{regId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRegistration(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }
  }
}

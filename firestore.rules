rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isBUAccount() { return request.auth.token.email.lower().endsWith("@bu.ac.th"); }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email.lower() == "kulachet.l@bu.ac.th" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // ===============================================================
    // 1. Instructors Collection
    // ===============================================================
    function isValidInstructor(data) {
      return data.keys().hasAll(['name', 'email', 'department']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 500 &&
             data.email is string && data.email.matches("^[a-zA-Z0-9._%+-]+@bu\\.ac\\.th$") &&
             data.department is string && data.department.size() > 0 &&
             // Handle both creation from CSV (no uid yet) and manual registration (with uid)
             (!('uid' in data) || (data.uid is string && data.uid.size() > 0));
    }

    match /instructors/{instructorId} {
      // Allowed searching/listing for authenticated BU users to find their profile
      allow get, list: if isSignedIn() && isBUAccount();
      
      allow create: if isSignedIn() && isBUAccount() && (
        isAdmin() || 
        (instructorId == request.auth.uid && incoming().uid == request.auth.uid)
      ) && isValidInstructor(incoming());

      allow update: if (isAdmin() || (isSignedIn() && existing().uid == request.auth.uid)) && isValidInstructor(incoming());
      
      allow delete: if isAdmin();
    }

    // ===============================================================
    // 2. Courses Collection
    // ===============================================================
    function isValidCourse(data) {
      return data.keys().hasAll(['title', 'instructorName', 'date']) &&
             data.title is string && data.title.size() > 0 &&
             data.instructorName is string && data.instructorName.size() > 0 &&
             data.date is string;
    }

    match /courses/{courseId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['totalRegistrations', 'sessions'])
      );
    }

    // ===============================================================
    // 3. Registrations Collection
    // ===============================================================
    // Path variable hardening applied to regId
    function isValidRegistration(data) {
      return data.keys().hasAll(['courseId', 'userId', 'userName', 'userEmail']) &&
             data.courseId is string &&
             data.userId is string &&
             data.userName is string &&
             data.userEmail is string;
    }

    match /registrations/{regId} {
      // List/Get: Owner can see their own, Admin can see all
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isBUAccount() && 
                    incoming().userId == request.auth.uid && 
                    isValidRegistration(incoming());

      allow update: if isAdmin() || (
        isSignedIn() && 
        existing().userId == request.auth.uid && 
        isValidRegistration(incoming()) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['attended', 'checkInAt', 'checkInSequenceNumber'])
      );

      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    // ===============================================================
    // 4. Mail Collection (Trigger Email extension)
    // ===============================================================
    match /mail/{mailId} {
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }

    // ===============================================================
    // 5. Evaluations Collection
    // ===============================================================
    match /evaluations/{evalId} {
      allow create: if isSignedIn() && isBUAccount() && incoming().userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ===============================================================
    // 6. Admins Collection (RBAC Master List)
    // ===============================================================
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable through Firebase Console for security
    }
    
    // Connection test document
    match /test/connection {
      allow read: if true;
    }
  }
}

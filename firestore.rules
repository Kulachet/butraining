rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function isRequestOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email.lower() == "kulachet.l@bu.ac.th" &&
             request.auth.token.email_verified == true;
    }

    function isValidInstructor(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'department']) &&
             data.email is string && data.email.matches("^[a-zA-Z0-9._%+-]+@bu\\.ac\\.th$") &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.department is string && data.department.size() > 0 &&
             (!('uid' in data) || (data.uid is string && data.uid.size() > 0));
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['courseId', 'userId', 'userName', 'userEmail', 'sequenceNumber']) &&
             data.courseId is string &&
             data.userId is string &&
             data.userName is string &&
             data.userEmail is string &&
             data.sequenceNumber is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /instructors/{instructorId} {
      allow read: if isAuthenticated();
      allow create: if (isOwner(instructorId) || isRequestOwner()) && isValidInstructor(request.resource.data);
      allow update: if (isOwner(instructorId) || isDocOwner() || (isAuthenticated() && resource.data.email == request.auth.token.email)) && isValidInstructor(request.resource.data);
    }

    match /courses/{courseId} {
      allow read: if true;
      // แก้ไข: อนุญาตให้ User ทั่วไปสามารถอัปเดตได้ "เฉพาะ" ฟิลด์จำนวนที่นั่ง (sessions, totalRegistrations) เท่านั้น
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sessions', 'totalRegistrations']));
      allow create, delete: if isAdmin();
    }

    match /registrations/{regId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRegistration(request.resource.data);
      // แก้ไข: อนุญาตให้ User เจ้าของรายการ สามารถอัปเดต 'attended' และ 'checkInAt' เพื่อเช็คอินได้
      allow update: if isAdmin() || (
        isAuthenticated() && 
        resource.data.userId == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attended', 'checkInAt'])
      );
      // แก้ไข: อนุญาตให้ User สามารถกดยกเลิกการลงทะเบียนของตัวเองได้
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /evaluations/{evaluationId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isAdmin();
      allow read, update, delete: if false;
    }
  }
}
